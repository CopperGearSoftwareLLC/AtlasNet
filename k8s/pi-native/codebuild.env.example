# Non-secret environment variables for local smoke tests or
# for copying into AWS CodeBuild project settings.

DOCKERHUB_NAMESPACE=yourdockerhubuser
DOCKERHUB_USERNAME=yourdockerhubuser

# Multi-arch publishing tags.
ATLASNET_IMAGE_TAG=latest
ATLASNET_IMAGE_TAG_AMD64=latest-amd64
ATLASNET_IMAGE_TAG_ARM64=latest-arm64

# Build tuning.
CMAKE_BUILD_TYPE=Release
JOBS=4

# Optional explicit image overrides. Leave commented to use defaults.
# ATLASNET_WATCHDOG_IMAGE=yourdockerhubuser/watchdog:latest-arm64
# ATLASNET_PROXY_IMAGE=yourdockerhubuser/proxy:latest-arm64
# ATLASNET_CARTOGRAPH_IMAGE=yourdockerhubuser/cartograph:latest-arm64
# ATLASNET_SANDBOX_SERVER_IMAGE=yourdockerhubuser/sandbox-server:latest-arm64

# Intentionally not included:
# DOCKERHUB_TOKEN
# Put that into AWS Secrets Manager or export it separately.
