# Copy to: .env
SERVER_IP=192.168.x.xx
# SSH login username on the server node
SERVER_SSH_USER=xxx

# Worker topology (space-separated list). For Linux+Pi workers:
# WORKER_IPS="192.168.x.21 192.168.x.31"
WORKER_IPS="192.168.x.21 192.168.x.31"

# Optional overrides
# SSH login username on the worker node (this is not the hostname)
WORKER_SSH_USER=pi
SSH_KEY=~/.ssh/id_ed25519
# Set to false only when using root SSH user and no sudo on nodes.
K3SUP_USE_SUDO=true
# K3S_API_ENDPOINT=k3s-api.lan

# Ports to free before bootstrap (space-separated).
# 7946: common Docker Swarm vs MetalLB conflict
# 6443: k3s API server (preflight cleanup on server only)
SERVER_PORT_CLEANUP_PORTS="7946"
WORKER_PORT_CLEANUP_PORTS="7946"

# AtlasNet runtime deploy settings (make atlasnet-deploy)
ATLASNET_K8S_NAMESPACE=atlasnet
DOCKERHUB_NAMESPACE=yourdockerhubuser
# Deploy tag. Recommended: keep this as a single multi-arch manifest tag.
# When you `kubectl apply` workloads, nodes will pull the correct image for their CPU arch.
ATLASNET_IMAGE_TAG=latest
ATLASNET_IMAGE_PULL_POLICY=IfNotPresent

# Recommended multi-arch publishing workflow when one machine can't build both archs:
# - Build+push amd64 images to:   ${DOCKERHUB_NAMESPACE}/*:${ATLASNET_IMAGE_TAG_AMD64}
# - Build+push arm64 images to:   ${DOCKERHUB_NAMESPACE}/*:${ATLASNET_IMAGE_TAG_ARM64}
# - Create/replace multi-arch manifest tag: ${DOCKERHUB_NAMESPACE}/*:${ATLASNET_IMAGE_TAG}
#   pointing at both arch-specific tags.
ATLASNET_IMAGE_TAG_AMD64=latest-amd64
ATLASNET_IMAGE_TAG_ARM64=latest-arm64

# Multi-arch build/push settings (make atlasnet-push)
# Platforms to build for:
ATLASNET_MULTIARCH_PLATFORMS=linux/amd64,linux/arm64
# Optional: name of an existing buildx builder to use.
# Leave empty to use your current default builder (recommended if your dev container
# is already configured to talk to a shared buildx container with cache).
# ATLASNET_MULTIARCH_BUILDER_NAME=my-shared-builder

# Optional explicit image overrides
# ATLASNET_WATCHDOG_IMAGE=yourdockerhubuser/watchdog:latest
# ATLASNET_PROXY_IMAGE=yourdockerhubuser/proxy:latest
# ATLASNET_SHARD_IMAGE=yourdockerhubuser/shard:latest
# ATLASNET_CARTOGRAPH_IMAGE=yourdockerhubuser/cartograph:latest

# Optional override if control-plane node auto-detect is wrong
# SERVER_NODE_NAME=your-server-node-name

# Docker Hub pull auth (needed for private repos)
DOCKERHUB_REQUIRE_AUTH=false
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_EMAIL=atlasnet@example.invalid
DOCKERHUB_SECRET_NAME=dockerhub-regcred

# (Optional) platform add-ons can be installed manually with kubectl/helm if needed.
