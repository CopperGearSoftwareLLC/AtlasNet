# Copy to: .env

# Server(s): space-separated entries; each may be "user@ip" or just "ip". First is primary.
SERVER_IPS="danny@192.168.88.10"
SERVER_SSH_USER=danny

# Workers: space-separated entries; each may be "user@ip" or just "ip". Can be empty.
WORKER_IPS="pi5@192.168.88.13"
WORKER_SSH_USER=pi

SSH_KEY=~/.ssh/id_ed25519
K3S_API_ENDPOINT=
K3S_EXTRA_ARGS=
K3S_AGENT_EXTRA_ARGS=
K3S_VERSION=v1.32.11+k3s1
K3SUP_VERSION=v0.13.15

# Ports to free before bootstrap.
SERVER_PORT_CLEANUP_PORTS="7946"
WORKER_PORT_CLEANUP_PORTS="7946"

# AtlasNet runtime images.
ATLASNET_K8S_NAMESPACE=atlasnet
ATLASNET_HELM_RELEASE_NAME=atlasnet
DOCKERHUB_NAMESPACE=yourdockerhubuser
ATLASNET_IMAGE_TAG=offline-20260327-1
ATLASNET_IMAGE_TAG_AMD64=offline-20260327-1-amd64
ATLASNET_IMAGE_TAG_ARM64=offline-20260327-1-arm64
ATLASNET_IMAGE_PULL_POLICY=IfNotPresent

# Optional explicit deployment refs. If unset, defaults to ${DOCKERHUB_NAMESPACE}/<name>:${ATLASNET_IMAGE_TAG}
# ATLASNET_WATCHDOG_IMAGE=
# ATLASNET_PROXY_IMAGE=
# ATLASNET_SANDBOX_SERVER_IMAGE=
# ATLASNET_CARTOGRAPH_IMAGE=

# Optional explicit per-arch source refs used when building the offline bundle.
# If unset, defaults to ${DOCKERHUB_NAMESPACE}/<name>:${ATLASNET_IMAGE_TAG_AMD64|ARM64}
# ATLASNET_WATCHDOG_IMAGE_AMD64=
# ATLASNET_WATCHDOG_IMAGE_ARM64=
# ATLASNET_PROXY_IMAGE_AMD64=
# ATLASNET_PROXY_IMAGE_ARM64=
# ATLASNET_SANDBOX_SERVER_IMAGE_AMD64=
# ATLASNET_SANDBOX_SERVER_IMAGE_ARM64=
# ATLASNET_CARTOGRAPH_IMAGE_AMD64=
# ATLASNET_CARTOGRAPH_IMAGE_ARM64=

ATLASNET_INTERNALDB_IMAGE=valkey/valkey-bundle:8.1.4
ATLASNET_CARTOGRAPH_INGRESS_CLASS_NAME=nginx
ATLASNET_CARTOGRAPH_INGRESS_HOST=cartograph.atlasnet.local

# Offline bundle locations.
ATLASNET_OFFLINE_ARCHES="amd64 arm64"
ATLASNET_OFFLINE_BUNDLE_DIR=./offline-bundle
ATLASNET_OFFLINE_REMOTE_DIR=/var/lib/atlasnet-offline
ATLASNET_OFFLINE_REGISTRY_HOST=192.168.88.10
ATLASNET_OFFLINE_REGISTRY_PORT=5000
ATLASNET_OFFLINE_REGISTRY_LOCAL_HOST=localhost
ATLASNET_OFFLINE_REGISTRY_CONTAINER_NAME=atlasnet-offline-registry
ATLASNET_OFFLINE_REGISTRY_DATA_DIR=./registry-data

# Optional platform add-ons.
INSTALL_METRICS_SERVER=true
INSTALL_METALLB=true
METALLB_ADDRESS_POOL=192.168.88.240-192.168.88.250
INSTALL_INGRESS_NGINX=true
INSTALL_CERT_MANAGER=true

# Pin chart versions for reproducible offline bundles.
METRICS_SERVER_CHART_VERSION=3.13.0
METALLB_CHART_VERSION=0.15.2
INGRESS_NGINX_CHART_VERSION=4.14.1
CERT_MANAGER_CHART_VERSION=v1.19.2

# Offline LLM.
# Default mode is external: watchdog points at a Docker Model Runner process on the control host.
ATLASNET_K8S_LLM_ENABLED=0
ATLASNET_LLM_ENDPOINT=
ATLASNET_LLM_DOCKER_HOST=
ATLASNET_LLM_DOCKER_PORT=12434
ATLASNET_LLM_HOST_PROXY_ENABLED=1
ATLASNET_LLM_HOST_PROXY_IMAGE=docker.io/alpine/socat:1.8.0.1
ATLASNET_LLM_HOST_PROXY_NAME=atlasnet-llm-host-proxy
ATLASNET_LLM_HOST_PROXY_SERVICE_PORT=12434
ATLASNET_LLM_HOST_PROXY_TARGET_PORT=12435
ATLASNET_LLM_MODEL_REF=huggingface.co/Dannys0n/Qwen3-1.7B-seed_gen_voronoi:Q4_K_M
ATLASNET_LLM_API_FORMAT=openai
ATLASNET_LLM_MODEL_ID=huggingface.co/dannys0n/qwen3-1.7b-seed_gen_voronoi:Q4_K_M
# Only used if you explicitly switch back to an in-cluster LLM pod.
ATLASNET_LLM_IMAGE=ghcr.io/ggml-org/llama.cpp:server
ATLASNET_LLM_SERVICE_PORT=8080
ATLASNET_LLM_MODEL_URL=https://huggingface.co/Dannys0n/Qwen3-1.7B-seed_gen_voronoi/resolve/main/Qwen3-1.7B-seed_gen_voronoi-Q4_K_M.gguf
ATLASNET_LLM_MODEL_FILE_NAME=Qwen3-1.7B-seed_gen_voronoi-Q4_K_M.gguf
ATLASNET_LLM_MODEL_FILE_PATH=./models/Qwen3-1.7B-seed_gen_voronoi-Q4_K_M.gguf
ATLASNET_LLM_MODEL_SEED_IMAGE=atlasnet/llm-model-seed:offline-20260327-1
ATLASNET_LLM_CONTEXT_SIZE=4096
ATLASNET_LLM_THREADS=4

# Optional override if auto-detect is wrong during atlasnet-deploy.
# SERVER_NODE_NAME=your-control-plane-node-name
